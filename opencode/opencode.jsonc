{
  "$schema": "https://opencode.ai/config.json",
  "share": "disabled",
  "default_agent": "plan",
  "model": "github-copilot/claude-sonnet-4.6",
  "small_model": "github-copilot/claude-haiku-4.5",
  "enabled_providers": [
    "github-copilot",
    "xai"
  ],
  "lsp": true,
  "formatter": true,
  "mcp": {
    "crates-io": {
      "type": "local",
      "command": [
        "cratesio-mcp",
        "--transport",
        "stdio"
      ],
      "enabled": true
    },
    "bun-mcp": {
      "type": "local",
      "command": [
        "bunx",
        "-y",
        "mcp-bun@latest"
      ],
      "enabled": true,
      "environment": {
        "DISABLE_NOTIFICATIONS": "true"
      }
    },
  },
  "permission": {
    "bun-mcp*": "deny", // only active in specific agent
    "crates-io*": "deny" // only active in specific agent
  },
  "agent": {
    "bun-expert": {
      "permission": {
        "bun-mcp*": "allow"
      }
    },
    "rust-expert": {
      "permission": {
        "crates-io*": "allow"
      }
    }
  }
}

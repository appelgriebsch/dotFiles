{
  "$schema": "https://opencode.ai/config.json",
  "share": "disabled",
  "default_agent": "plan",
  "model": "github-copilot/claude-sonnet-5",
  "small_model": "github-copilot/claude-haiku-4.5",
  "enabled_providers": [
    "github-copilot",
    "xai"
  ],
  "lsp": true,
  "formatter": true,
  "mcp": {
    "crates-io": {
      "type": "local",
      "command": [
        "cratesio-mcp",
        "--transport",
        "stdio"
      ],
      "enabled": true
    },
    "bun-mcp": {
      "type": "local",
      "command": [
        "bunx",
        "-y",
        "mcp-bun@latest"
      ],
      "enabled": true,
      "environment": {
        "DISABLE_NOTIFICATIONS": "true"
      }
    },
    "datadog": {
      "type": "remote",
      "enabled": true,
      "url": "https://mcp.datadoghq.eu/api/unstable/mcp-server/mcp"
    },
    "github": {
      "type": "local",
      "enabled": true,
      "command": [
        "github-mcp-server",
        "stdio"
      ],
      "environment": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "<token>"
      }
    },
  },
  "permission": {
    "atlassian*": "ask",
    "bun-mcp*": "deny", // only active in specific agent
    "crates-io*": "deny", // only active in specific agent
    "datadog*": "deny", // only active in specific agent
    "github*": "ask"
  },
  "agent": {
    "plan": {
      "permission": {
        "datadog*": "allow"
      }
    },
    "bun-code-reviewer": {
      "permission": {
        "bun-mcp*": "allow"
      }
    },
    "rust-code-reviewer": {
      "permission": {
        "crates-io*": "allow"
      }
    },
    "datadog-analyzer": {
      "permission": {
        "datadog*": "allow"
      }
    }
  }
}

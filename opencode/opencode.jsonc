{
  "$schema": "https://opencode.ai/config.json",
  "share": "disabled",
  "default_agent": "plan",
  "model": "xai/grok-4.3",
  "small_model": "xai/grok-4.3",
  "enabled_providers": [
    "github-copilot",
    "xai"
  ],
  "lsp": true,
  "formatter": true,
  "mcp": {
    "crates-io": {
      "type": "local",
      "command": [
        "cratesio-mcp",
        "--transport",
        "stdio"
      ],
      "enabled": true
    },
    "bun-mcp": {
      "type": "local",
      "command": [
        "bunx",
        "-y",
        "mcp-bun@latest"
      ],
      "enabled": true,
      "environment": {
        "DISABLE_NOTIFICATIONS": "true"
      }
    },
    "github": {
      "type": "local",
      "enabled": true,
      "command": [
        "github-mcp-server",
        "stdio"
      ],
      "environment": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "<token>"
      }
    },
  },
  "plugin": [
    "@datadog/opencode-plugin"
  ],
  "permission": {
    "bun-mcp*": "deny", // only active in specific agent
    "crates-io*": "deny", // only active in specific agent
    "datadog*": "deny", // only active in specific agent
    "github*": "ask", // ask for permission to access any GitHub API
    "github_get*": "allow", // allow only GET requests to GitHub API
    "github_list*": "allow", // allow only list requests to GitHub API
    "github_search*": "allow", // allow only search requests to Git
    "github_*_read*": "allow" // allow only read requests to GitHub API
  },
  "agent": {
    "plan": {
      "permission": {
        "datadog*": "allow"
      }
    },
    "bun-code-reviewer": {
      "permission": {
        "bun-mcp*": "allow"
      }
    },
    "rust-code-reviewer": {
      "permission": {
        "crates-io*": "allow"
      }
    },
    "datadog-analyzer": {
      "permission": {
        "datadog*": "allow"
      }
    }
  }
}

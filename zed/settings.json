{
  "context_servers": {
    "datadog-mcp": {
      "enabled": true,
      "remote": false,
      "settings": {
        "site": "EU",
        "toolsets": [
          "all"
        ]
      }
    },
    "bun-docs-mcp": {
      "enabled": true,
      "remote": false,
      "settings": {}
    },
    "mcp-server-github": {
      "enabled": true,
      "remote": false,
      "settings": {
        "github_personal_access_token": "<token>"
      }
    }
  },
  "outline_panel": {
    "dock": "right",
  },
  "project_panel": {
    "dock": "right",
    "git_status_indicator": true,
    "diagnostic_badges": true,
    "bold_folder_labels": true,
  },
  "edit_predictions": {
    "provider": "copilot",
  },
  "auto_install_extensions": {
    "basher": true,
    "codebook": true,
    "coverage-lsp": true,
    "dependi": true,
    "docker-compose": true,
    "dockerfile": true,
    "env": true,
    "git-firefly": true,
    "github-actions": true,
    "graphql": true,
    "html": true,
    "julia": true,
    "just": true,
    "make": true,
    "marksman": true,
    "mdx": true,
    "mermaid": true,
    "oxc": true,
    "package-swift-lsp": true,
    "postgres-language-server": true,
    "proto": true,
    "ruff": true,
    "sql": true,
    "sqruff": true,
    "stylelint": true,
    "swift": true,
    "toml": true,
    "wat": true,
    "xml": true,
  },
  "theme": {
    "mode": "system",
    "light": "Ayu Light",
    "dark": "Ayu Mirage",
  },
  "icon_theme": "Zed (Default)",
  "base_keymap": "SublimeText",
  "buffer_font_family": "FiraCode Nerd Font Mono",
  "buffer_font_size": 15,
  "ui_font_family": ".SystemUIFont",
  "ui_font_size": 15,
  "vim_mode": true,
  "confirm_quit": true,
  "restore_on_startup": "launchpad",
  "auto_signature_help": true,
  "relative_line_numbers": "enabled",
  "inlay_hints": {
    "enabled": true,
  },
  "minimap": {
    "show": "auto",
  },
  "which_key": {
    "enabled": true,
  },
  "git_panel": {
    "show_count_badge": true,
    "file_icons": true,
    "tree_view": true,
    "dock": "right",
  },
  "indent_guides": {
    "enabled": true,
    "coloring": "indent_aware",
  },
  "tabs": {
    "git_status": true,
    "file_icons": true,
    "show_diagnostics": "errors",
  },
  "collaboration_panel": {
    "dock": "right",
    "button": false,
  },
  "preview_tabs": {
    "enable_preview_multibuffer_from_code_navigation": true,
    "enable_preview_from_file_finder": true,
    "enable_keep_preview_on_code_navigation": true,
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "auto_update": true,
  "vim": {
    "toggle_relative_line_numbers": true,
    "use_system_clipboard": "on_yank",
    "use_smartcase_find": true,
  },
  "title_bar": {
    "show_sign_in": false,
    "show_branch_status_icon": true,
    "show_user_picture": true,
    "show_onboarding_banner": false,
  },
  "terminal": {
    "show_count_badge": true,
    "font_family": "FiraCode Nerd Font Mono",
    "env": {
      "EDITOR": "zed --wait",
    },
  },
  "file_types": {
    "Dockerfile": ["Dockerfile", "Dockerfile.*"],
    "JSON": ["json", "jsonc", "*.code-snippets"],
    "GitHub Actions": [".github/workflows/*.yml", ".github/workflows/*.yaml"],
  },
  "file_scan_exclusions": [
    "**/.git",
    "**/.svn",
    "**/.hg",
    "**/CVS",
    "**/.DS_Store",
    "**/Thumbs.db",
    "**/.classpath",
    "**/.settings",
    "**/out",
    "**/dist",
    "**/target",
    "**/.vscode",
    "**/node_modules",
  ],
  "agent": {
    "favorite_models": [
      {
        "provider": "copilot_chat",
        "model": "claude-sonnet-5",
        "enable_thinking": true,
        "effort": "high",
      },
    ],
    "sidebar_side": "left",
    "dock": "left",
    "play_sound_when_agent_done": "always",
    "use_modifier_to_send": true,
    "inline_assistant_model": {
      "provider": "copilot_chat",
      "model": "claude-sonnet-5",
    },
    "default_profile": "write",
    "default_model": {
      "effort": "high",
      "enable_thinking": true,
      "provider": "copilot_chat",
      "model": "claude-sonnet-5",
    },
  },
  "languages": {
    "YAML": {
      "formatter": "language_server",
      "format_on_save": "off",
    },
    "Python": {
      "formatter": {
        "language_server": {
          "name": "ruff",
        },
      },
      "format_on_save": "off",
      "language_servers": [
        "ty",
        "ruff",
        "!basedpyright",
        "!pyrefly",
        "!pyright",
        "!pylsp",
      ],
    },
  },
  "lsp": {
    "jdtls": {
      "settings": {
        "java_home": "/Library/Java/JavaVirtualMachines/graalvm-21.jdk/Contents/Home/",
        "lombok_support": true,
      },
    },
    "rust-analyzer": {
      "initialization_options": {
        "inlayHints": {
          "maxLength": null,
          "lifetimeElisionHints": {
            "enable": "skip_trivial",
            "useParameterNames": true,
          },
          "closureReturnTypeHints": {
            "enable": "always",
          },
        },
        "check": {
          "command": "clippy",
          "workspace": true,
        },
      },
    },
    "vtsls": {
      "settings": {
        "javascript": {
          "inlayHints": {
            "parameterNames": {
              "enabled": "all",
              "suppressWhenArgumentMatchesName": false,
            },
            "parameterTypes": {
              "enabled": true,
            },
            "variableTypes": {
              "enabled": true,
              "suppressWhenTypeMatchesName": true,
            },
            "propertyDeclarationTypes": {
              "enabled": true,
            },
            "functionLikeReturnTypes": {
              "enabled": true,
            },
            "enumMemberValues": {
              "enabled": true,
            },
          },
        },
        "typescript": {
          "inlayHints": {
            "parameterNames": {
              "enabled": "all",
              "suppressWhenArgumentMatchesName": false,
            },
            "parameterTypes": {
              "enabled": true,
            },
            "variableTypes": {
              "enabled": true,
              "suppressWhenTypeMatchesName": true,
            },
            "propertyDeclarationTypes": {
              "enabled": true,
            },
            "functionLikeReturnTypes": {
              "enabled": true,
            },
            "enumMemberValues": {
              "enabled": true,
            },
          },
        },
      },
    },
    "yaml-language-server": {
      "settings": {
        "yaml": {
          "format": {
            "enable": true,
            "singleQuote": true,
          },
        },
      },
    },
  },
}
